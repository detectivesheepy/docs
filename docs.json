{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mint Starter Kit",
  "colors": {
    "primary": "#0067ff",
    "light": "#0067ff",
    "dark": "#0067ff"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      }
    ]
  },
  "logo": "/logo.png",
  "navbar": {
    "links": [
      {
        "label": "Use KODA",
        "href": "https://playkoda.vercel.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/detectivesheepy/koda",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  },
  "background": {
    "color": {
      "light": "#000000"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "family": "Open Sans",
    "format": "woff",
    "heading": {
      "family": "Poppins"
    }
  },
  "errors": {
    "404": {
      "title": "uh oh 😰",
      "description": "that doesn't exist!"
    }
  },
  "seo": {
    "indexing": "all"
  },
  "metadata": {
    "timestamp": false
  },
  "search": {
    "prompt": "Search for something"
  },
  "icons": {
    "library": "fontawesome"
  },
  "banner": {
    "content": "KODA is so cool guys,,,",
    "dismissible": true
  }
}
